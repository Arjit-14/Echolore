# ── Secrets & Environment Variables ──────────────────────────────────────────
# CRITICAL: .env contains API keys and must NEVER be committed.
# Copy .env.example to .env and fill in your own values.
.env
.env.*
!.env.example

# ── Python ───────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
*.pyd
*.pyo
.Python
build/
dist/
*.egg-info/
.eggs/

# ── Virtual Environments ──────────────────────────────────────────────────────
venv/
env/
.venv/
.env.local
.env.production

# ── Jupyter ───────────────────────────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb

# ── IDE / Editor ──────────────────────────────────────────────────────────────
.vs/
.vscode/*
!.vscode/extensions.json
.idea/
*.swp
*.swo
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*~

# ── OS ────────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── Logs ─────────────────────────────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ── Data: processed & reports (regenerated by ETL pipeline) ──────────────────
data/processed/
data/reports/

# ── Data: large raw files & local pipeline checkpoints ───────────────────────
# Keep tracked: small JSONL checkpoints and raw caches (< ~50MB)
# Exclude: datagov (deprioritized - API access requires manual registration)
data/raw/datagov/
# Exclude: very large binary files if ever added
*.parquet
*.csv.gz
*.pkl
*.db
*.sqlite

# ── Node / Frontend ──────────────────────────────────────────────────────────
node_modules/
dist-ssr/
*.local

# ── Docker ────────────────────────────────────────────────────────────────────
# docker-compose.override.yml

# ── Pytest / Coverage ─────────────────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
.tox/

# ── MyPy ─────────────────────────────────────────────────────────────────────
.mypy_cache/

# ── History (VS Code extension artifact) ─────────────────────────────────────
.history/
