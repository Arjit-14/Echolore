# Arkana — Environment Variables Template
# ─────────────────────────────────────────────────────────────────────────────
# HOW TO USE:
#   cp .env.example .env
#   # Then edit .env and fill in your own values.
#
# WARNING: Never commit .env to git. It is excluded by .gitignore.
# This file (.env.example) contains ONLY placeholder values and is safe to commit.
# ─────────────────────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=arkana
POSTGRES_USER=arkana
POSTGRES_PASSWORD=arkana_secret

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── API Keys ──────────────────────────────────────────────────────────────────
# data.gov.in — Free registration at: https://data.gov.in/user/register
# NOTE: data.gov.in is deprioritized for Phase 1. Leave empty if not needed.
DATAGOV_API_KEY=

# Google Gemini — Required for Phase 3+ AI layer
# Get key at: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Europeana — Phase 3+ only (optional)
# Get key at: https://api.europeana.eu/
EUROPEANA_API_KEY=

# ── Logging ────────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
